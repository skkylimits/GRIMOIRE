// https://code.visualstudio.com/docs/languages/markdown
// This is my attempt to create a custom keybinding file for Visual Studio Code simulating the browser experience.
[
	{
		"key": "ctrl+t",
		"command": "workbench.action.files.newUntitledFile", // Create new file
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+n",
		"command": "workbench.action.newWindow" // Create new window
	},
	{
		"key": "ctrl+shift+[",
		"command": "workbench.files.action.collapseExplorerFolders" // Collapse folders
	},
	{
		"key": "ctrl+shift+.",
		"command": "editor.action.insertSnippet", // Insert console.log snippet
		"args": {
			"snippet": "console.log($1);$2"
		},
		"when": "editorTextFocus"
	},
	{
		"key": "alt+f", // Now runs combined task
		"command": "workbench.action.tasks.runTask",
		"args": "Normalize and Update Markdown Assets" // Run the combined task
	},
	// {
	//     "key": "ctrl+shift+space",
	//     "command": "editor.action.insertSnippet",
	//     "when": "editorTextFocus"
	// },
	{
		"key": "ctrl+shift+3",
		"command": "outline.focus"
	},
	{
		"key": "ctrl+shift+space",
		"command": "workbench.action.gotoSymbol",
		"when": "!accessibilityHelpIsShown && !accessibleViewIsShown"
	},
	{
		"key": "ctrl+shift+alt+space",
		"command": "workbench.action.showAllSymbols"
	}
]
// Paste these settings to Preference: Open Keyboard Shortcuts (JSON) in Visual Studio Code.
// To launch the Define Keybinding widget, press Ctrl+K Ctrl+K
// https://code.visualstudio.com/docs/getstarted/keybindings#_keyboard-layoutindependent-bindings
// ADD: a way to switch between vscode windows
// AHK - Autohotkey
// disable: Add Cursor Above
// disable Add Cursor Below
// default: cursorTop
// default: cursorBottom
