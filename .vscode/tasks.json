// sudo apt install perl
// regex: (\.\.\/)+public
// perl: perl -i -p -e 's/(\.\.\/)+public//g' your_file.txt
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Normalize Image Paths In Markdown",
			"type": "shell",
			"command": "npm run normalize-markdown-image ${file}",
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		}
	]
}

// s/!\[([^\]]*)\]\(([^)]+\/)(\.\.\/)+public([^)]*)\)/![\1](\2public\4)/g
