{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Normalize Image Paths In Markdown",
			"type": "shell",
			"command": "node utils/NormalizeMarkdownImageSyntax.js ${file}",
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "Update Alt Text In Markdown",
			"type": "shell",
			"command": "node utils/updateAltTextMarkdownImageSyntax.js ${file}",
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		}
	]
}
