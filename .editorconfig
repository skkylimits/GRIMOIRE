# editorconfig.org

# Top-level configuration file
root = true

[*]
indent_size = 2
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Override for Windows-specific scripts (CRLF)
[*.bat]
end_of_line = crlf

[*.cmd]
end_of_line = crlf

# Override for markdown and text files
[*.{md,txt}]
trim_trailing_whitespace = true
insert_final_newline = true