{
	"name": "grimoire",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "nuxt dev",
		"build": "nuxt build",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"setup": "bash scripts/cli/setup.sh",
		"reset": "node scripts/cli/reset.js",
		"typecheck": "nuxt typecheck",
		"test": "pnpm vitest",
		"test:watch": "pnpm vitest --watch",
		"test:coverage": "pnpm vitest run --coverage",
		"test:verbose": "pnpm vitest --reporter verbose",
		"test:ui": "vitest --ui",
		"test:report": "vitest run --coverage && vitest-coverage-reporter",
		"measure:dev": "node scripts/metrics/measure-dev.js",
		"measure:build": "node scripts/metrics/measure-build.js",
		"measure:preview": "node scripts/metrics/measure-preview.js",
		"measure:reset": "node scripts/metrics/measure-reset.js",
		"sync:context": "cp CLAUDE.md GEMINI.md && cp CLAUDE.md AGENTS.md"
	},
	"dependencies": {
		"@googlemaps/markerclusterer": "^2.6.2",
		"@iconify-json/lucide": "^1.2.99",
		"@iconify-json/simple-icons": "^1.2.75",
		"@iconify-json/vscode-icons": "^1.2.45",
		"@nuxt/content": "^3.12.0",
		"@nuxt/image": "^2.0.0",
		"@nuxt/scripts": "0.13.2",
		"@nuxt/ui": "^4.6.0",
		"@sidebase/nuxt-auth": "^1.2.0",
		"@unhead/vue": "^2.1.12",
		"better-sqlite3": "^12.8.0",
		"next-auth": "4.24.13",
		"nuxt": "^4.4.2",
		"nuxt-llms": "0.2.0",
		"nuxt-og-image": "^6.2.6"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.7.3",
		"@nuxt/eslint": "^1.15.2",
		"@nuxt/test-utils": "^4.0.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^10.1.0",
		"eslint-plugin-format": "^2.0.1",
		"typescript": "^6.0.2",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.2",
		"vue-tsc": "^3.2.6"
	},
	"resolutions": {
		"unimport": "4.1.1"
	}
}
